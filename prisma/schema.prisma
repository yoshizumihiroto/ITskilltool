generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MEMBER
  MENTOR
  TM
  ADMIN
}

enum ImprovementStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum PlanStatus {
  ACTIVE
  COMPLETED
}

enum PlanItemStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model Team {
  id      Int    @id @default(autoincrement())
  name    String
  members User[]
}

model User {
  id           Int    @id @default(autoincrement())
  name         String
  email        String @unique
  passwordHash String
  role         Role   @default(MEMBER)

  teamId   Int?
  team     Team? @relation(fields: [teamId], references: [id])
  mentorId Int?
  mentor   User? @relation("MentorMembers", fields: [mentorId], references: [id])

  mentees              User[]             @relation("MentorMembers")
  assessments          AssessmentResult[]
  studyLogs            StudyLog[]
  learningPlans        LearningPlan[]     @relation("PlanOwner")
  createdPlans         LearningPlan[]     @relation("PlanCreator")
  feedbackReceived     Feedback[]         @relation("FeedbackMember")
  feedbackGiven        Feedback[]         @relation("FeedbackMentor")
  improvementsAsMember ImprovementCycle[] @relation("ImprovementMember")
  improvementsAsMentor ImprovementCycle[] @relation("ImprovementMentor")
  quizResults          QuizResult[]

  createdAt DateTime @default(now())
}

model SkillCategory {
  id          Int    @id @default(autoincrement())
  name        String
  description String @default("")
  icon        String @default("📚")
  order       Int    @default(0)

  elements SkillElement[]
}

model SkillElement {
  id         Int           @id @default(autoincrement())
  categoryId Int
  category   SkillCategory @relation(fields: [categoryId], references: [id])
  name       String
  icon       String        @default("📌")
  definition String        @default("")
  evalNote   String        @default("")
  order      Int           @default(0)

  levels           SkillLevel[]
  assessments      AssessmentResult[]
  trainingContents TrainingContent[]
  feedback         Feedback[]
}

model SkillLevel {
  id             Int          @id @default(autoincrement())
  skillElementId Int
  skillElement   SkillElement @relation(fields: [skillElementId], references: [id])
  level          Int
  name           String
  descriptor     String
}

model AssessmentResult {
  id    Int @id @default(autoincrement())
  score Int
  level Int

  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  skillElementId Int
  skillElement   SkillElement @relation(fields: [skillElementId], references: [id])

  createdAt DateTime @default(now())
}

model TrainingContent {
  id              Int     @id @default(autoincrement())
  title           String
  description     String  @default("")
  minLevel        Int     @default(1)
  contentUrl      String  @default("")
  durationMinutes Int     @default(60)
  tags            String  @default("")
  learningText    String  @default("")
  quizJson        String  @default("[]")
  isAiGenerated   Boolean @default(false)

  skillElementId Int
  skillElement   SkillElement @relation(fields: [skillElementId], references: [id])

  studyLogs         StudyLog[]
  learningPlanItems LearningPlanItem[]
  quizResults       QuizResult[]
}

model QuizResult {
  id            Int    @id @default(autoincrement())
  score         Int
  correctCount  Int
  totalCount    Int
  assessedLevel Int
  answers       String @default("[]")

  userId            Int
  user              User            @relation(fields: [userId], references: [id])
  trainingContentId Int
  trainingContent   TrainingContent @relation(fields: [trainingContentId], references: [id])

  createdAt DateTime @default(now())
}

model LearningPlan {
  id            Int        @id @default(autoincrement())
  shortTermGoal String     @default("")
  midTermGoal   String     @default("")
  status        PlanStatus @default(ACTIVE)

  userId      Int
  user        User @relation("PlanOwner", fields: [userId], references: [id])
  createdById Int
  createdBy   User @relation("PlanCreator", fields: [createdById], references: [id])

  items     LearningPlanItem[]
  createdAt DateTime           @default(now())
}

model LearningPlanItem {
  id     Int            @id @default(autoincrement())
  order  Int            @default(0)
  status PlanItemStatus @default(PENDING)

  planId            Int
  plan              LearningPlan    @relation(fields: [planId], references: [id])
  trainingContentId Int
  trainingContent   TrainingContent @relation(fields: [trainingContentId], references: [id])
}

model StudyLog {
  id              Int      @id @default(autoincrement())
  durationMinutes Int      @default(0)
  memo            String   @default("")
  loggedAt        DateTime @default(now())

  userId            Int
  user              User             @relation(fields: [userId], references: [id])
  trainingContentId Int?
  trainingContent   TrainingContent? @relation(fields: [trainingContentId], references: [id])
}

model Feedback {
  id      Int    @id @default(autoincrement())
  content String

  mentorId       Int
  mentor         User          @relation("FeedbackMentor", fields: [mentorId], references: [id])
  memberId       Int
  member         User          @relation("FeedbackMember", fields: [memberId], references: [id])
  skillElementId Int?
  skillElement   SkillElement? @relation(fields: [skillElementId], references: [id])

  createdAt DateTime @default(now())
}

model ImprovementCycle {
  id     Int               @id @default(autoincrement())
  issue  String
  action String            @default("")
  result String            @default("")
  status ImprovementStatus @default(OPEN)

  mentorId Int
  mentor   User @relation("ImprovementMentor", fields: [mentorId], references: [id])
  memberId Int
  member   User @relation("ImprovementMember", fields: [memberId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
